NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Demo mock mode (UI review without a backend). Default ON: leave unset or != "0"
# and the frontend serves all data from an in-memory mock (src/lib/mock) — `npm run
# dev` alone drives the whole UI. Set to 0 to talk to the real backend above.
NEXT_PUBLIC_USE_MOCK=1
