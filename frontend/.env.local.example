NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Demo mock mode. When set to anything other than "0" (or left unset), the
# frontend serves all data from an in-memory mock (src/lib/mock) and needs NO
# backend / Oracle / LLM — `npm run dev` alone drives the whole demo.
# Set to 0 to talk to the real backend at NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_USE_MOCK=1
