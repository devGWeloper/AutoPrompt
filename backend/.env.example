# --- Oracle DB ---
# python-oracledb thin DSN form: user/password@host:port/SERVICE_NAME
ORACLE_DSN=pm_user/pm_password@localhost:1521/XEPDB1

# Test DB (in-memory SQLite for pytest). Leave default unless customizing.
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

# --- LLM provider API keys ---
# Required only for the providers you actually invoke in node tests.
# RAGAS Judge needs no separate key: it auto-uses the first configured
# provider below (priority: openai > anthropic > google).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# RAGAS engine: auto (real ragas when lib+key available, else fallback) |
# fallback (always heuristic) | ragas (force real ragas).
RAGAS_ENGINE=auto

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- App ---
LOG_LEVEL=INFO
