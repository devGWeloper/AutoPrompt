# ============================================================================
# Prompt-Management backend — environment (.env)
# Copy to backend/.env and fill in. Each non-comment line must be KEY=VALUE
# (no leading text, no spaces around '='), or python-dotenv will skip it.
# ============================================================================

# --- Oracle DB (three separate values) -------------------------------------
# ORACLE_DSN is the BARE connection string handed to python-oracledb as `dsn`:
#   - Easy Connect: "host:port/service_name"
#   - tnsnames alias
#   - full TNS descriptor: "(DESCRIPTION=(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)
#     (HOST=...)(PORT=...)))(CONNECT_DATA=(SERVICE_NAME=...)))"
# Keep the whole descriptor on ONE line (python-dotenv reads everything after
# the first '=' as the value, but a real line break inside the descriptor will
# break parsing). No surrounding quotes needed.
# Do NOT embed user/password in the DSN.
ORACLE_USER=pm_user
ORACLE_PASSWORD=pm_password
ORACLE_DSN=(DESCRIPTION=(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=host.example.internal)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=ORCLPDB1)))

# In-memory SQLite for pytest. Leave as-is unless customizing.
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

# --- Internal LLM gateway (OpenAI-compatible) ------------------------------
# Used by the RAGAS judge — the only LLM this system calls. LLM_ENDPOINT is the
# base URL (the OpenAI SDK appends /chat/completions),
# e.g. http://llm-gateway.internal:8000/v1
LLM_MODEL_NAME=
LLM_ENDPOINT=
LLM_API_KEY=

# --- RAGAS -----------------------------------------------------------------
# auto (real ragas when lib + LLM_ENDPOINT available, else heuristic fallback) |
# fallback (always heuristic) | ragas (force real ragas)
RAGAS_ENGINE=auto

# --- Embedding model (separate OpenAI-compatible gateway allowed) ----------
# Required for RAGAS context metrics (context_precision / context_recall);
# LLM-only metrics still run if EMBEDDING_ENDPOINT is unset. Same shape as the
# LLM trio (name / base URL / key). May point at a different gateway than LLM_*.
EMBEDDING_MODEL_NAME=
EMBEDDING_ENDPOINT=
EMBEDDING_API_KEY=

# --- External chat / super-agent (flow-level RAGAS answer generation) ------
# RUN_MODE=stub (default): answers are deterministic in-process placeholders.
# RUN_MODE=external: POST to EXTERNAL_AGENT_BASE_URL with body
#   {"message", "user_id"} and headers
#     auth-key: <EXTERNAL_AUTH_KEY>
#     user-id:  <EXTERNAL_USER_ID>
# The external model reads SYSTEM_PROMPT/USER_PROMPT/MODEL_NM from the active
# PM_NODE_PROMPT_VER row directly.
RUN_MODE=stub
EXTERNAL_AGENT_BASE_URL=
EXTERNAL_AUTH_KEY=
EXTERNAL_USER_ID=pm-test

# --- CORS / App ------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
