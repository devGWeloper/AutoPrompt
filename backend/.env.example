# --- Oracle DB ---
# python-oracledb thin DSN form: user/password@host:port/SERVICE_NAME
ORACLE_DSN=pm_user/pm_password@localhost:1521/XEPDB1

# Test DB (in-memory SQLite for pytest). Leave default unless customizing.
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

# --- LLM provider API keys ---
# Required only for the providers you actually invoke in node tests.
# RAGAS Judge needs no separate key: it auto-uses the first configured
# provider below (priority: openai > anthropic > google).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# RAGAS engine: auto (real ragas when lib+key available, else fallback) |
# fallback (always heuristic) | ragas (force real ragas).
RAGAS_ENGINE=auto

# RAGAS real-engine judge chat model, per provider. Used when a run doesn't
# pin judge_model; if both are unset the run fails per-case with a clear error
# (no default). Example values below.
GOOGLE_JUDGE_MODEL=          # e.g. gemini-2.5-flash
OPENAI_JUDGE_MODEL=          # e.g. gpt-4o-mini
ANTHROPIC_JUDGE_MODEL=       # e.g. claude-3-5-haiku-latest

# RAGAS real-engine embedding models. REQUIRED when the real engine runs with
# the matching judge provider; if blank the run fails per-case with a clear
# error (no default — won't silently pick a model).
# Example values — google: models/text-embedding-004 / openai: text-embedding-3-small
GOOGLE_EMBEDDING_MODEL=
OPENAI_EMBEDDING_MODEL=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- App ---
LOG_LEVEL=INFO
