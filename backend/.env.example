# ============================================================================
# Prompt-Management backend — environment (.env)
# Copy to backend/.env and fill in. Each non-comment line must be KEY=VALUE
# (no leading text, no spaces around '='), or python-dotenv will skip it.
# ============================================================================

# --- Oracle DB (three separate values) -------------------------------------
# ORACLE_DSN is the BARE connection string handed to python-oracledb as `dsn`:
#   Easy Connect "host:port/service_name", a tnsnames alias, or a full
#   "(DESCRIPTION=...)" descriptor. Do NOT embed user/password in it.
ORACLE_USER=pm_user
ORACLE_PASSWORD=pm_password
ORACLE_DSN=host:port/service_name

# In-memory SQLite for pytest. Leave as-is unless customizing.
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

# --- Internal LLM gateway (OpenAI-compatible) ------------------------------
# Used by the RAGAS judge — the only LLM this system calls. LLM_ENDPOINT is the
# base URL (the OpenAI SDK appends /chat/completions),
# e.g. http://llm-gateway.internal:8000/v1
LLM_MODEL_NAME=
LLM_ENDPOINT=
LLM_API_KEY=

# --- RAGAS -----------------------------------------------------------------
# auto (real ragas when lib + LLM_ENDPOINT available, else heuristic fallback) |
# fallback (always heuristic) | ragas (force real ragas)
RAGAS_ENGINE=auto

# Embedding model name served by the same internal gateway. Required for real
# RAGAS context metrics (precision/recall); LLM-only metrics still run if unset.
# Example: text-embedding-3-small
OPENAI_EMBEDDING_MODEL=

# --- External chat / super-agent (flow-level RAGAS answer generation) ------
# RUN_MODE=stub (default): answers are deterministic in-process placeholders, so
#   flow RAGAS runs end-to-end before the agent is connected.
# RUN_MODE=external: drive the real chat endpoint (set EXTERNAL_AGENT_BASE_URL +
#   confirm EXTERNAL_CHAT_PATH). See the connect-prompt-mgmt skill.
RUN_MODE=stub
EXTERNAL_AGENT_BASE_URL=
EXTERNAL_CHAT_PATH=/chat
EXTERNAL_CHAT_TYPE=default
EXTERNAL_USER_ID=pm-test
# EXTERNAL_IS_SUPER_AGENT=true
# EXTERNAL_A2A_REMOTE_URLS=http://a,http://b

# --- CORS / App ------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
